#!/bin/sh
set -eu

REAL_BIN="/usr/share/access-os-installer/install-access-real"

if [ ! -x "$REAL_BIN" ]; then
    printf '%s\n' "install-access: packaged installer binary not found at $REAL_BIN" >&2
    exit 1
fi

if [ "$(id -u)" -eq 0 ]; then
    exec "$REAL_BIN" "$@"
fi

if command -v sudo >/dev/null 2>&1; then
    exec sudo "$REAL_BIN" "$@"
fi

if command -v pkexec >/dev/null 2>&1; then
    exec pkexec "$REAL_BIN" "$@"
fi

printf '%s\n' "install-access: root privileges are required. Install sudo or pkexec, or run as root." >&2
exit 1
